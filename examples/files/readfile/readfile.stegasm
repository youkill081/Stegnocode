section .data
    path DB "./readfile/readfile_example_file"

section .text
    FILE_OPEN R0 path ; R0 = file descriptor

loop:
    CALL end_if_end_of_file
    FILE_READ_BYTE R1 R0 ; R1 = byte read
    DISPLAY_C R1 ; Display char saved in R1
    JMP loop

; ------
; Utils Function
; ------

end_if_end_of_file:
    FILE_IS_BYTE_REMAINING R1 R0
    CMP R1 0
    JE end_if_end_of_file-halt
    RET

end_if_end_of_file-halt:
    FILE_CLOSE R0
    LOAD_32 R0 0
    HALT


