; Display the fibonacci sequence

section .data
    X  DB 48
    F1 DD 0
    F2 DD 1

section .text
fibo:
    LOAD_8 R1 [X]
    CMP R1 0
    JE fibo_end

    LOAD_32 R1 [F1]
    DISPLAY_N R1

    LOAD_32 R2 [F2]
    ADD R1 R2
    STORE_32 R2 F1
    STORE_32 R1 F2

    LOAD_8 R1 [X]
    SUB R1 1
    STORE_8 R1 X

    JMP fibo
fibo_end:
    LOAD_32 R0 0
    HALT