; Draw the current controller block on the map ;
section .text
draw_current_block:
    LOADA R1, [current_block_type]
    LOADA R2, [current_block_rotation]
    LOADA R3, [current_block_skin]
    LOADA R4, [current_block_X]
    LOADA R5, [current_block_Y]
    LOADA R6, 0 ; No padding for current_block
    LOADA R7, 0 ; No padding for current_block

    CALL draw_alive_block

    RET