section .text
move_current_down:
    LOAD_8 R1, [current_block_Y]
    ADD R1, 1
    STORE_8 R1, current_block_Y
    RET

move_current_left:
    LOAD_8 R1, [current_block_X]
    SUB R1, 1
    STORE_8 R1, current_block_X
    RET

move_current_right:
    LOAD_8 R1, [current_block_X]
    ADD R1, 1
    STORE_8 R1, current_block_X
    RET