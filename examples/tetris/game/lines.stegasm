section .data
    lines_string DB "LINES-..."
    broken_lines DB 0

section .text

; Display Lines ;

display_broken_lines:
    LOAD_32 R0, lines_string
    ADD R0, 6 ; Move pointer to the number

    LOAD_8 R1, 3 ; Number of digits
    LOAD_8 R2,  [broken_lines] ; Number of broken lines
    CALL number_to_string

    LOAD_8 R0, 104
    LOAD_8 R1, 15
    WINDOW_DRAW_TEXT R0 R1 lines_string
    RET