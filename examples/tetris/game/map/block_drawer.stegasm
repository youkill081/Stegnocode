; Utils file to draw all block types ;

section .text

draw_white_background_at_coordinate: ; R0 -> X, R1 -> Y
    WINDOW_RESET_TEXTURE_COLOR_MASK
    WINDOW_DRAW_TEXTURE R0 R1 block_white_background
    RET

; ------------ ;

draw_skin_at_coordinate: ; R0 -> X, R1 -> Y, R2 -> Skin index
    CMP R2, 1
    JE draw_skin_type_1
    CMP R2, 2
    JE draw_skin_type_2
    RET

draw_skin_type_1:
    WINDOW_DRAW_TEXTURE R0 R1 block_skin_1
    RET

draw_skin_type_2:
    WINDOW_DRAW_TEXTURE R0 R1 block_skin_2
    RET

; ------------ ;

set_color_by_block_type: ; R2 -> Block type
    PUSH R3
    PUSH R4
    PUSH R5

    CALL set_level_color

    CMP R2, 1
    JE set_color_type_1
    CMP R2, 2
    JE set_color_type_2
    CMP R2, 3
    JE set_color_type_3
    CMP R2, 4
    JE set_color_type_4
    CMP R2, 5
    JE set_color_type_5
    CMP R2, 6
    JE set_color_type_6
    CMP R2, 7
    JE set_color_type_7
    JMP set_color_end

set_color_type_1: ; I - Cyan
    ADD R3, 10
    ADD R4, 10
    ADD R5, 10
    JMP set_color_end

set_color_type_2: ; O - Yellow
    ADD R3, 20
    ADD R4, 20
    ADD R5, 20
    JMP set_color_end

set_color_type_3: ; T - Purple
    ADD R3, 0
    ADD R4, 0
    ADD R5, 0
    JMP set_color_end

set_color_type_4: ; S - Green
    ADD R3, 30
    ADD R4, 30
    ADD R5, 30
    JMP set_color_end

set_color_type_5: ; Z - Red
    ADD R3, 40
    ADD R4, 40
    ADD R5, 40
    JMP set_color_end

set_color_type_6: ; J - Blue
    ADD R3, 50
    ADD R4, 50
    ADD R5, 50
    JMP set_color_end

set_color_type_7: ; L - Orange
    ADD R3, 50
    ADD R4, 50
    ADD R5 50
    JMP set_color_end

set_color_end:
    MOD R3, 255
    MOD R4, 255
    MOD R5, 255

    WINDOW_SET_TEXTURE_COLOR_MASK R3 R4 R5
    POP R5
    POP R4
    POP R3
    RET